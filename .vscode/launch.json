{
  "configurations": [
    {
      "type": "java",
      "name": "ProductServiceApplication",
      "request": "launch",
      "mainClass": "com.practice.product_service.ProductServiceApplication",
      "projectName": "product-service"
    },
    {
      "type": "java",
      "name": "Spring Boot-ConfigServiceApplication<config-service>",
