      "projectName": "config-service",
      "args": "",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "type": "java",
      "name": "Spring Boot-DiscoveryServiceApplication<discovery-service>",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "mainClass": "com.practice.discovery_service.DiscoveryServiceApplication",
      "projectName": "discovery-service",
      "args": "",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
